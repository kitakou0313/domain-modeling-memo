# ============================================================
# .gitignore for F# / .NET projects
# Based on: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
# ============================================================

# --------------------------------
# Build artifacts
# --------------------------------
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
bld/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
**/[Bb]in/*
[Dd]ebug/x64/
[Dd]ebugPublic/x64/
[Rr]elease/x64/
[Rr]eleases/x64/
bin/x64/
obj/x64/
[Dd]ebug/x86/
[Dd]ebugPublic/x86/
[Rr]elease/x86/
[Rr]eleases/x86/
bin/x86/
obj/x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# .NET build outputs
artifacts/
.artifacts/
project.lock.json
project.fragment.lock.json
*.binlog
MSBuild_Logs/

# --------------------------------
# NuGet
# --------------------------------
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets

# --------------------------------
# F# specific tools
# --------------------------------

# FAKE - F# Make
**/.fake/

# Ionide (VS Code F# plugin)
**/.ionide/

# Paket dependency manager
**/.paket/paket.exe
paket-files/

# Fody - auto-generated XML schema
FodyWeavers.xsd

# --------------------------------
# IDE: Visual Studio
# --------------------------------
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
.vs/
Generated\ Files/
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
*.dotCover
.axoCover/*
!.axoCover/settings.json
_NCrunch_*
.NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*
**/.localhistory/
.vshistory/
MigrationBackup/

# --------------------------------
# IDE: VS Code
# --------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix

# --------------------------------
# IDE: JetBrains Rider
# --------------------------------
.idea/

# --------------------------------
# Test results & coverage
# --------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.VisualState.xml
TestResult.xml
nunit-*.xml
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml
BenchmarkDotNet.Artifacts/
OpenCover/

# --------------------------------
# OS generated files
# --------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --------------------------------
# Environment / secrets
# --------------------------------
*.env
*.pfx
*.publishsettings

# --------------------------------
# Compiled outputs (keep source, ignore binaries)
# --------------------------------
*.ilk
*.obj
*.idb
*.pch
*.pdb
*.ipdb
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.tlog
*.scc
*.pidb
*.svclog
mono_crash.*

.fake